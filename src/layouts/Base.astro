---
import Analytics from "../components/Analytics.astro";

interface Props {
  lang: string;
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  active: "en" | "es" | "pt";
  langLabel?: string;
  footerLocation?: string;
  langPaths?: { en: string; es: string; pt: string };
  backHref?: string;
}
const {
  lang,
  title,
  description,
  canonical,
  ogTitle = "Andrés Vidal",
  ogDescription,
  active,
  langLabel = "Language",
  footerLocation = "Montevideo, Uruguay · andresvidal.dev",
  langPaths = { en: "/", es: "/es/", pt: "/pt/" },
  backHref,
} = Astro.props;

const privacyLabel = ({ en: "Privacy", es: "Privacidad", pt: "Privacidade" } as Record<string, string>)[lang] ?? "Privacy";
const privacyUrl = ({ en: "/privacy/", es: "/es/privacy/", pt: "/pt/privacy/" } as Record<string, string>)[lang] ?? "/privacy/";

const origin = "https://andresvidal.dev";
const hreflangs = [
  { code: "en", href: `${origin}${langPaths.en}` },
  { code: "es", href: `${origin}${langPaths.es}` },
  { code: "pt", href: `${origin}${langPaths.pt}` },
  { code: "x-default", href: `${origin}${langPaths.en}` },
];

const person = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Andrés Vidal",
  givenName: "Andrés",
  familyName: "Vidal",
  url: "https://andresvidal.dev/",
  image: "https://andresvidal.dev/andres.jpg",
  jobTitle: "Computer Scientist & Statistician",
  worksFor: { "@type": "Organization", name: "WyeWorks", url: "https://www.wyeworks.com/" },
  alumniOf: { "@type": "CollegeOrUniversity", name: "Universidad de la República", url: "https://www.udelar.edu.uy/" },
  address: { "@type": "PostalAddress", addressLocality: "Montevideo", addressCountry: "UY" },
  knowsAbout: ["Statistical machine learning", "Projection Pursuit Random Forests", "High-performance computing", "Software engineering", "Statistics"],
  sameAs: ["https://github.com/andres-vidal", "https://orcid.org/0009-0008-6350-7585", "https://www.linkedin.com/in/andresvidalberriel/"],
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function () { try { var t = localStorage.getItem("theme"); if (t === "dark" || t === "light") document.documentElement.setAttribute("data-theme", t); } catch (e) {} })();
      function toggleTheme() { var d = document.documentElement, c = d.getAttribute("data-theme"), k = c ? c === "dark" : matchMedia("(prefers-color-scheme: dark)").matches, n = k ? "light" : "dark"; d.setAttribute("data-theme", n); try { localStorage.setItem("theme", n); } catch (e) {} }
    </script>
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />
    <meta name="description" content={description} />
    <meta name="author" content="Andrés Vidal" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {hreflangs.map((h) => <link rel="alternate" hreflang={h.code} href={h.href} />)}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:image" content="https://andresvidal.dev/andres.jpg" />
    <meta name="twitter:card" content="summary" />
    <link rel="stylesheet" href="/styles.css" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(person)} />
    <Analytics />
  </head>
  <body>
    <div class="wrap">
      <nav class="langbar" aria-label={langLabel}>
        {backHref && <a href={backHref}>← andresvidal.dev</a>}
        {backHref && <span class="bar-spacer"></span>}
        <a href={langPaths.en} aria-current={active === "en" ? "true" : undefined}>EN</a>
        <a href={langPaths.es} aria-current={active === "es" ? "true" : undefined}>ES</a>
        <a href={langPaths.pt} aria-current={active === "pt" ? "true" : undefined}>PT</a> <button class="themebtn" type="button" onclick="toggleTheme()" aria-label="Toggle light or dark theme"><span class="sun"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="4.5"></circle><path d="M12 1.5v2.5M12 20v2.5M3.5 12H1M23 12h-2.5M5 5l1.7 1.7M17.3 17.3 19 19M19 5l-1.7 1.7M6.7 17.3 5 19"></path></svg></span><span class="moon"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path></svg></span></button>
      </nav>

      <svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
        <symbol id="icon-github" viewBox="0 0 16 16"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path></symbol>
        <symbol id="icon-mail" viewBox="0 0 24 24"><path fill="currentColor" d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"></path></symbol>
        <symbol id="icon-linkedin" viewBox="0 0 24 24"><path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"></path></symbol>
        <symbol id="icon-orcid" viewBox="0 0 256 256"><circle cx="128" cy="128" r="128" fill="#A6CE39"></circle><path fill="#fff" d="M86.3 186.2H70.9V79.1h15.4v107.1z"></path><path fill="#fff" d="M108.9 79.1h41.6c39.6 0 57 28.3 57 53.6 0 27.5-21.5 53.6-56.8 53.6h-41.8V79.1zm15.4 93.3h24.5c34.9 0 42.9-26.5 42.9-39.7 0-21.5-13.7-39.7-43.7-39.7h-23.7v79.4z"></path><path fill="#fff" d="M88.7 56.8c0 5.5-4.5 10.1-10.1 10.1s-10.1-4.6-10.1-10.1c0-5.6 4.5-10.1 10.1-10.1 5.6 0 10.1 4.6 10.1 10.1z"></path></symbol>
        <symbol id="icon-doc" viewBox="0 0 24 24"><path fill="currentColor" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zm0 2 4 4h-4V4zM8 13h8v1.5H8V13zm0 3h8v1.5H8V16zm0-6h5v1.5H8V10z"></path></symbol>
        <symbol id="icon-pen" viewBox="0 0 24 24"><path fill="currentColor" d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"></path></symbol>
      </svg>

      <slot />

      <footer>
        <span>© 2026 Andrés Vidal</span>
        <span>{footerLocation} · <a class="footer-link" href={privacyUrl}>{privacyLabel}</a></span>
      </footer>
    </div>
  </body>
</html>
