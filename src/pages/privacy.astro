---
import Base from "../layouts/Base.astro";
const langPaths = { en: "/privacy/", es: "/es/privacy/", pt: "/pt/privacy/" };
---
<Base
  lang="en"
  title="Privacy · Andrés Vidal"
  description="Privacy notice for andresvidal.dev: cookieless Cloudflare Web Analytics, no personal tracking."
  canonical="/privacy/"
  active="en"
  langPaths={langPaths}
  backHref="/"
>
  <section>
    <div class="wrap" style="padding:0">
      <div class="legal">
        <h1>Privacy</h1>
        <p class="legal-sub">andresvidal.dev · updated July 2026</p>
        <p>This site uses <b>Cloudflare Web Analytics</b> to measure aggregate traffic — page views, referrers, and similar signals. <b>It does not use cookies</b>: it stores nothing on your device, does not track visitors across sites, and does not collect personally identifying information. Visits are counted without cookies or fingerprinting. For details, see <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener">Cloudflare's privacy policy</a>.</p>
        <p>No other analytics or tracking tools are used. For any questions, write to <a href="mailto:andres@andresvidal.dev">andres@andresvidal.dev</a>.</p>
      </div>
    </div>
  </section>
</Base>
